{
  "name": "vantris",
  "version": "0.6.0",
  "description": "A modern bundler for JavaScript/TypeScript",
  "type": "module",
  "license": "MIT",
  "keywords": [
    "bundler",
    "build-tool",
    "dev-server",
    "typescript"
  ],
  "author": "Vantris",
  "repository": {
    "type": "git",
    "url": "https://github.com/vantrisjs/vantris"
  },
  "homepage": "https://github.com/vantrisjs/vantris",
  "bugs": {
    "url": "https://github.com/vantrisjs/vantris/issues"
  },
  "bin": {
    "vantris": "dist/cli/index.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./client": {
      "types": "./client.d.ts"
    },
    "./package.json": "./package.json"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "client.d.ts"
  ],
  "engines": {
    "node": ">=20.11.0"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "clean": "rm -rf dist",
    "prepublishOnly": "pnpm run build"
  },
  "devDependencies": {
    "@types/ws": "^8.18.1",
    "less": "^4.6.7",
    "sass": "^1.101.0",
    "tsup": "^8.3.5",
    "vitest": "^4.1.9"
  },
  "dependencies": {
    "chokidar": "^5.0.0",
    "esbuild": "^0.28.1",
    "h3": "2.0.1-rc.22",
    "lightningcss": "^1.32.0",
    "magic-string": "^0.30.21",
    "postcss": "^8.5.15",
    "postcss-load-config": "^6.0.1",
    "rolldown": "^1.1.3",
    "ws": "^8.21.0"
  },
  "peerDependencies": {
    "less": "*",
    "sass": "*"
  },
  "peerDependenciesMeta": {
    "sass": { "optional": true },
    "less": { "optional": true }
  }
}
